{
  "projectType": "api-service",
  "projectName": "ms-alumnos",
  "projectDescription": "A NestJS microservice for managing student (alumno) records, communicating over NATS messaging and backed by a PostgreSQL database.",
  "theme": "luma",
  "primaryColor": "#4F46E5",
  "lightColor": "#EEF2FF",
  "darkColor": "#1E1B4B",
  "navigation": {
    "tabs": [
